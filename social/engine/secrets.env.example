# Copy this file to "secrets.env" and fill in your values. secrets.env is gitignored.
# One Facebook Page token + Page ID per brand. See setup-meta.md for how to get these.

# --- KieferBuilt (facebook.com/KieferBuiltContracting) ---
FB_PAGE_ACCESS_TOKEN_KIEFER=
FB_PAGE_ID_KIEFER=

# --- InterlockGo (your existing Page) ---
# If you already minted a token in your old interlockgo-social app, paste the same value here.
FB_PAGE_ACCESS_TOKEN_INTERLOCKGO=
FB_PAGE_ID_INTERLOCKGO=

# Local review server port (default 4500).
REVIEW_PORT=4500
